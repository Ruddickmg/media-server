{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "autoApprove": true,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "configMigration": true,
  "branchConcurrentLimit": 2,
  "nix": {
    "enabled": true
  },
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ]
}
